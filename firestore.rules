rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Productos: cualquiera puede leer, solo admins autenticados pueden escribir
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config: solo admins
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
